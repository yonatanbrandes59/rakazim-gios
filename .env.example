# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin Auth ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=Admin@123
JWT_SECRET=change-me-in-production-merakzim-2024

# ── Supabase (optional - leave empty for demo/mock mode) ───────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Free Mode (prevents any paid API calls) ────────────────────
FREE_MODE=true
ALLOW_PAID_MESSAGING=false

# ── Messaging Provider ─────────────────────────────────────────
# options: mock | resend_email | whatsapp_cloud | twilio
MESSAGING_PROVIDER=mock

# ── Resend Email (free: 3000 emails/month) ─────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── WhatsApp Cloud API (disabled by default, paid) ─────────────
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Twilio WhatsApp (disabled by default, paid) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Cron Protection ────────────────────────────────────────────
CRON_SECRET=change-me-cron-secret-2024
