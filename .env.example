# ============================================================
# merakzim-v2 — Environment Variables Reference
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------
# Application URLs
# ------------------------------------------------------------

# Public base URL for the app (used to build questionnaire links, etc.)
# Example: https://merakzim.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Authentication (REQUIRED in production)
# ------------------------------------------------------------

# Secret used to sign JWT tokens. Must be a long random string (min 32 chars).
# Generate with: openssl rand -hex 32
# WARNING: The hard-coded fallback will throw in production if this is missing.
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Admin account credentials. Change both before deploying.
# WARNING: The app will throw in production if these are missing.
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=replace-with-a-strong-password-min-8-chars

# ------------------------------------------------------------
# Cron job (REQUIRED in production)
# ------------------------------------------------------------

# Secret value sent by Vercel Cron in the x-cron-secret header.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# Set this in the Vercel dashboard under Project Settings > Environment Variables.
# WARNING: The app will throw at startup in production if this is missing or too short.
CRON_SECRET=replace-with-a-long-random-secret-min-32-chars

# ------------------------------------------------------------
# Supabase (optional — omit to run in in-memory demo mode)
# ------------------------------------------------------------

# These three vars together activate Supabase persistence.
# Leave all three empty to use the in-memory store (demo/dev mode).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Vercel Blob (optional — used for file storage alongside Supabase)
# ------------------------------------------------------------

# Token for Vercel Blob storage (if you use @vercel/blob).
# Create one in the Vercel dashboard under Storage > Blob.
BLOB_READ_WRITE_TOKEN=

# ------------------------------------------------------------
# Messaging — FREE_MODE (default: wa.me links only)
# ------------------------------------------------------------

# Set to "true" to block all outbound paid messaging APIs.
# When true, only manual wa.me WhatsApp links are generated.
# This is the safe default for all deployments.
FREE_MODE=true

# Set to "true" ONLY if you have a paid WhatsApp Cloud API plan
# and have explicitly configured WHATSAPP_CLOUD_API_TOKEN below.
# Has no effect unless FREE_MODE=false.
ALLOW_PAID_MESSAGING=false

# ------------------------------------------------------------
# Messaging provider selection (optional)
# ------------------------------------------------------------

# Which messaging provider to use: "mock" | "whatsapp_cloud" | "resend_email" | "twilio"
# Defaults to "mock" (wa.me link generation only) when unset.
MESSAGING_PROVIDER=mock

# ------------------------------------------------------------
# AI Brain — Claude or Gemini (optional, pick ONE)
# ------------------------------------------------------------
# Activates the LLM brain:
#  • One-line AI candidate summaries in the admin dashboard
#  • Personalized coordinator alert messages
#  • Free-text WhatsApp conversation with completed candidates
# Provider selection: ANTHROPIC_API_KEY wins if both are set.
# Leave both empty → the app silently falls back to the rule-based brain.
# NOTHING is ever billed while these are empty.

# Option A — Claude (paid, best quality): https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=

# Option B — Google Gemini (FREE tier, no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=

# Phone number (05xxxxxxxx) that receives "new candidate" admin alerts.
ADMIN_PHONE=

# ------------------------------------------------------------
# Email — Resend (optional)
# ------------------------------------------------------------

# API key from https://resend.com — required for sending confirmation emails.
# Leave empty to disable email sending.
RESEND_API_KEY=re_your_resend_api_key_here

# From address used for outbound emails (must be verified in Resend).
RESEND_FROM_EMAIL=noreply@your-domain.com

# ------------------------------------------------------------
# WhatsApp Webhook (Meta) — REQUIRED for inbound messages
# ------------------------------------------------------------

# Token you configure in Meta Developer Console → App → WhatsApp → Configuration → Verify Token.
# Use the same random string here and in the Vercel dashboard.
# Generate with: openssl rand -hex 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-random-verify-token-here

# App Secret from Meta Developer Console → App Settings → Basic → App Secret.
# Used to verify webhook request signatures (x-hub-signature-256 header).
# The POST handler reads the raw body with `await req.text()` before JSON.parse()
# so that the HMAC digest is computed over the exact bytes Meta signed.
WHATSAPP_APP_SECRET=

# ── Meta Console setup steps ──────────────────────────────────────────────────
# 1. Go to developers.facebook.com → Your App → WhatsApp → Configuration
# 2. Callback URL : https://your-vercel-url.vercel.app/api/whatsapp/webhook
# 3. Verify Token : value of WHATSAPP_WEBHOOK_VERIFY_TOKEN (above)
# 4. Subscribe to : messages, message_deliveries, message_reads
# 5. After Meta verifies, the GET handler returns hub.challenge — no auth needed.
#    The POST handler is secured by the x-hub-signature-256 HMAC check only;
#    do NOT add JWT/cookie auth to /api/whatsapp/webhook (Meta sends no session).
# ─────────────────────────────────────────────────────────────────────────────

# ------------------------------------------------------------
# WhatsApp Cloud API (optional — only when ALLOW_PAID_MESSAGING=true)
# ------------------------------------------------------------

# WARNING: Paid WhatsApp Cloud API. Do NOT set these unless you
# have a verified Meta Business account and an approved template.
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ------------------------------------------------------------
# Twilio WhatsApp (optional — only when ALLOW_PAID_MESSAGING=true)
# ------------------------------------------------------------

# WARNING: Paid Twilio API. Only fill these if you use Twilio for WhatsApp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ============================================================
# VERCEL DASHBOARD — Environment Variables checklist
# Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================
#
# The following must be explicitly set in Vercel (do NOT rely on code defaults):
#
#  WHATSAPP_WEBHOOK_VERIFY_TOKEN  — same random string as above; used in Meta Console
#  WHATSAPP_APP_SECRET            — from Meta App Settings → Basic → App Secret
#  FREE_MODE=true                 — must be set explicitly; never rely on absence
#  ALLOW_PAID_MESSAGING=false     — must be set explicitly; never rely on absence
#  CRON_SECRET                    — random secret (min 32 chars) sent in x-cron-secret
#                                    header by Vercel Cron; generate with openssl rand -hex 32
#
# Also set all required vars from the sections above:
#  JWT_SECRET, ADMIN_EMAIL, ADMIN_PASSWORD
#  SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY  (if using Supabase)
#  NEXT_PUBLIC_APP_URL            — your production Vercel URL
